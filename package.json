{
  "name": "slaido",
  "version": "0.1.0",
  "description": "AI-driven slide generator powered by Electrobun and reveal.js",
  "license": "MIT",
  "author": "Yuji Yamamoto",
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "start": "bun run build:dev && ./node_modules/.bin/electrobun dev",
    "build:dev": "bun install && ./node_modules/.bin/electrobun build",
    "build:prod": "bun install && ./node_modules/.bin/electrobun build --env=stable",
    "test": "bun test"
  },
  "dependencies": {
    "electrobun": "^1.16.0",
    "@anthropic-ai/sdk": "^0.39.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.0.0"
  }
}
